{
  "name": "video-edit-tools",
  "version": "1.0.0",
  "description": "Deterministic video editing SDK for AI agents. Ships with MCP tools.",
  "author": "swimmingkiim",
  "license": "MIT",
  "homepage": "https://github.com/swimmingkiim/video-edit-tools#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swimmingkiim/video-edit-tools.git"
  },
  "bugs": {
    "url": "https://github.com/swimmingkiim/video-edit-tools/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "video-edit-tools-mcp": "dist/mcp/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./mcp": "./dist/mcp/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "example:shorts": "npx tsx examples/generate-shorts.ts",
    "example:youtube": "npx tsx examples/generate-youtube.ts",
    "prepublishOnly": "npm run build && npm run test:coverage"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@modelcontextprotocol/sdk": "^1.1.0",
    "@xenova/transformers": "^2.17.0",
    "fluent-ffmpeg": "^2.1.3",
    "image-edit-tools": "^1.0.8",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^20.14.2",
    "@vitest/coverage-v8": "^1.6.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "video",
    "editing",
    "mcp",
    "ai-agent",
    "ffmpeg",
    "typescript",
    "claude"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
